{
  "expo": {
    "name": "SporHive",
    "slug": "SporHive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "sporhive",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.sporhive.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/images/ios-dark.png",
        "tinted": "./assets/images/ios-tinted.png",
        "light": "./assets/images/ios-light.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.18.2"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./assets/images/splash-icon-light.png",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#FFFFFF"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SporHive to access your photos so you can update your profile image."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SporHive to use your location to discover nearby playgrounds on the map."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {
        "origin": "sporhive://",
        "links": [
          {
            "path": "r/:token"
          }
        ]
      },
      "API_BASE_URL": "",
      "ENV_NAME": "",
      "eas": {
        "projectId": "d8e46091-2c57-4cbe-bdb9-a1a56df7e54d"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}