{
  "expo": {
    "name": "SporHive",
    "slug": "SporHive",
    "owner": "sporhive",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },

    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "sporhive",

    "userInterfaceStyle": "automatic",

    "newArchEnabled": true,
    "jsEngine": "hermes",

    "assetBundlePatterns": [
      "**/*"
    ],

    "splash": {
      "image": "./assets/images/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#232323"
    },

    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },

    "android": {
      "package": "com.sporhive.app",
      "versionCode": 1,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true,

      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],

      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],

      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "sporhive"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },

    "ios": {
      "supportsTablet": true,

      "bundleIdentifier": "com.sporhive.app",

      "icon": {
        "dark": "./assets/images/ios-dark.png",
        "tinted": "./assets/images/ios-tinted.png",
        "light": "./assets/images/ios-light.png"
      },

      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow SporHive to access your photos so you can update your profile image.",
        "NSLocationWhenInUseUsageDescription": "Allow SporHive to use your location to discover nearby playgrounds on the map."
      }
    },

    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",

      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.18.2"
        }
      ],

      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon-light.png",

          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#232323"
          },

          "imageWidth": 200
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SporHive to access your photos so you can update your profile image."
        }
      ],

      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow SporHive to use your location to discover nearby playgrounds on the map."
        }
      ],

      "@react-native-community/datetimepicker"
    ],

    "extra": {
      "router": {
        "origin": "sporhive://",

        "links": [
          {
            "path": "r/:token"
          }
        ]
      },

      "ENV_NAME": "production",

      "eas": {
        "projectId": "d8e46091-2c57-4cbe-bdb9-a1a56df7e54d"
      }
    },

    "experiments": {
      "typedRoutes": true
    }
  }
}